"എന്റർ നമ്പർ : " കാണിക്കുക;
നമ്പർ = അക്കംവാങ്ങിക്കുക;
i = 2;
കൊടി = 1;

i നെകാൾ (നമ്പർ / 2) + 1 വലുതാണ് എങ്കിൽ ആവർത്തിക്കുക {
    നമ്പർ % i ഉം 0 ഉം തുല്യമാണ് എങ്കിൽ {
        കൊടി = 0;
    }
    i = i + 1;
}

കൊടി ഉം 0 ഉം തുല്യമാണ് എങ്കിൽ {
    "Prime alle" കാണിക്കുക;
} അതല്ലെങ്കിൽ {
    "Prime aane" കാണിക്കുക;
}
